                "emailReceivers": "[if(empty(parameters('criticalEmailAddress')), createArray(), createArray(createObject('name', 'critical-email', 'emailAddress', parameters('criticalEmailAddress'), 'useCommonAlertSchema', true())))]",
                "smsReceivers": [],
                "webhookReceivers": []
              }
            },
            {
              "type": "Microsoft.Insights/actionGroups",
              "apiVersion": "2023-01-01",
              "name": "[format('ag-ops-medium-{0}-{1}', parameters('resourcePrefix'), parameters('environment'))]",
              "location": "[parameters('location')]",
              "properties": {
                "groupShortName": "[take(format('opsmed{0}', variables('actionGroupPrefix')), 12)]",
                "enabled": true,
                "emailReceivers": "[if(empty(parameters('opsEmailAddress')), createArray(), createArray(createObject('name', 'ops-email', 'emailAddress', parameters('opsEmailAddress'), 'useCommonAlertSchema', true())))]",
                "smsReceivers": [],
                "webhookReceivers": []
              }
            },

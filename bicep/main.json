              }
            },
            {
              "condition": "[parameters('enableBaselineAlerts')]",
              "type": "Microsoft.Insights/scheduledQueryRules",
              "apiVersion": "2023-12-01",
              "name": "[format('sqr-heartbeat-missing-{0}-{1}', parameters('resourcePrefix'), parameters('environment'))]",
              "location": "[parameters('location')]",
              "properties": {
                "description": "Triggers when monitored hosts stop reporting heartbeat.",
                "displayName": "Heartbeat Missing",
                "enabled": true,
                "severity": 1,
                "scopes": [
                  "[parameters('workspaceResourceId')]"
                ],
                "evaluationFrequency": "PT5M",
                "windowSize": "PT10M",
                "criteria": {
                  "allOf": [
                    {
                      "query": "Heartbeat | summarize lastHeartbeat=max(TimeGenerated) by Computer | where lastHeartbeat < ago(10m)",
                      "timeAggregation": "Count",
                      "operator": "GreaterThan",
                      "threshold": 0,
                      "failingPeriods": {
                        "numberOfEvaluationPeriods": 1,
                        "minFailingPeriodsToAlert": 1
                      }
                    }
                  ]
                },
                "actions": {
                  "actionGroups": [
                    "[resourceId('Microsoft.Insights/actionGroups', format('ag-oncall-critical-{0}-{1}', parameters('resourcePrefix'), parameters('environment')))]"
                  ]
                },
                "autoMitigate": true
              },
              "dependsOn": [
                "[resourceId('Microsoft.Insights/actionGroups', format('ag-oncall-critical-{0}-{1}', parameters('resourcePrefix'), parameters('environment')))]"
              ]
            },
            {
              "type": "Microsoft.AlertsManagement/actionRules",
              "apiVersion": "2021-08-08",
              "name": "[format('ar-maintenance-window-{0}-{1}', parameters('resourcePrefix'), parameters('environment'))]",

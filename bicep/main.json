              "defaultValue": true,
              "metadata": {
                "description": "Enable deployment of baseline alert rules."
              }
            },
            "criticalEmailAddress": {
              "type": "string",
              "defaultValue": "",
              "metadata": {
                "description": "Optional email receiver for critical Action Group."
              }
            },
            "opsEmailAddress": {
              "type": "string",
              "defaultValue": "",
              "metadata": {
                "description": "Optional email receiver for medium Action Group."
              }
            },
            "itsmWebhookServiceUri": {
              "type": "string",
              "defaultValue": "",
              "metadata": {
                "description": "Optional webhook receiver for ITSM integration."
              }
            }
          },
          "variables": {
            "actionGroupPrefix": "[format('{0}{1}', parameters('resourcePrefix'), parameters('environment'))]"
          },
          "resources": [
            {
              "type": "Microsoft.Insights/actionGroups",
